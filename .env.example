# Vorlage für lokale Secrets — kopiere diese Datei nach ".env" (oder nach
# "api_keys.env" am in SETUP.md genannten Ort) und trage echte Werte ein.
# Die echten Dateien sind per .gitignore ausgeschlossen und gehören NIE ins Repo.

# Google AI Studio (Gemini Image) — für tools/gen_scene.py & gen_image_fixed.py
GOOGLE_AI_KEY=

# Optional: OpenAI-Fallback (gpt-image) in gen_image_fixed.py
OPENAI_API_KEY=

# Optional: xAI Grok — nur für "Podcast Video/video_producer.py"
XAI_API_KEY=
