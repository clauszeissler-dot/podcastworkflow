# Vorlage für die Website (Vite). Nach ".env" kopieren und echte Werte eintragen.
# Die echte .env ist per .gitignore ausgeschlossen.
# Der Supabase "publishable"/anon-Key ist für den Client-Einsatz gedacht (durch RLS geschützt),
# trotzdem nicht den service_role-Key hier ablegen.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_HCAPTCHA_SITE_KEY=
